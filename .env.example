# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos (desarrollo local) ─────────────────────────────────────────
